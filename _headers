/*
  Cache static assets for 1 year (content hash in filename ensures cache busting).
  HTML and JSON are not cached so content updates show immediately.
*/
/img/*
  Cache-Control: public, max-age=31536000, immutable

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable
